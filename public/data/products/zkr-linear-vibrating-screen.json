  "features": {
    "zh": [
      "直线运动轨迹：物料在筛面上呈直线运动，分层效果好",
      "双电机驱动系统：振动稳定，物料处理更均匀",
      "筛网可选规格多：适应各种物料筛分需求",
      "耐磨性好：使用高耐磨材料，延长设备使用寿命",
      "维护方便：模块化设计，便于更换筛网和维修"
    ],
    "en": [
      "Linear Motion Trajectory: Material moves in straight line on screen surface, better stratification",
      "Dual Motor Drive System: Stable vibration, more uniform material processing",
      "Multiple Screen Specifications: Adaptable to various material screening requirements",
      "High Wear Resistance: Using high wear-resistant materials, extending equipment service life",
      "Easy Maintenance: Modular design for convenient screen replacement and repair"
    ]
  },
  "applications": {
    "zh": [
      "矿山：各类矿石筛分与分级",
      "建材：砂石生产线物料筛选",
      "冶金：原料预处理与成品分级",
      "化工：颗粒物料精细分级",
      "煤炭：煤炭洗选与分级处理"
    ],
    "en": [
      "Mining: Various ore screening and classification",
      "Construction Materials: Sand and stone production line material screening",
      "Metallurgy: Raw material preprocessing and finished product classification",
      "Chemical Industry: Fine classification of granular materials",
      "Coal: Coal washing and grading"
    ]
  },
