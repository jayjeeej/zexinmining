  "features": {
    "zh": [
      "双轴激振器驱动：产生强劲振动力，提高筛分效率，确保物料均匀分布",
      "高强度筛箱结构：采用优质钢材，增强抗疲劳性和使用寿命，减少维护频率",
      "多层筛网设计：可同时完成多粒度分级作业，最多可配置三层筛网",
      "精密动平衡系统：有效降低工作噪音和振动传递，提升设备稳定性",
      "模块化快换筛网：便于维护和更换，大幅减少停机时间，提高生产效率",
      "可调激振参数：振幅和频率可根据不同物料特性进行优化调节"
    ],
    "en": [
      "Dual-Shaft Exciter Drive: Generates powerful vibration force, enhances screening efficiency, ensures uniform material distribution",
      "High-Strength Screen Box: Made of premium steel, improves fatigue resistance and service life, reduces maintenance frequency",
      "Multi-Layer Screen Design: Simultaneously performs multi-size classification operations, configurable with up to three screen layers",
      "Precision Dynamic Balance System: Effectively reduces operational noise and vibration transfer, enhances equipment stability",
      "Modular Quick-Change Screen: Facilitates maintenance and replacement, significantly reduces downtime, improves production efficiency",
      "Adjustable Excitation Parameters: Amplitude and frequency can be optimized according to different material characteristics"
    ]
  },
  "applications": {
    "zh": [
      "矿山行业：矿石筛分、分级和脱水",
      "建材领域：砂石生产线、煤炭分选",
      "冶金工业：原料预处理、成品分级",
      "化工行业：颗粒物料分级",
      "环保工程：固体废物分离处理"
    ],
    "en": [
      "Mining Industry: Ore screening, classification and dewatering",
      "Construction Materials: Sand production lines, coal sorting",
      "Metallurgical Industry: Raw material preprocessing, finished product classification",
      "Chemical Industry: Particulate material grading",
      "Environmental Engineering: Solid waste separation processing"
    ]
  },
